{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role, score, and badges",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["citizen", "admin"] },
        "contributionScore": { "type": "integer" },
        "badges": { "type": "array" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email", "displayName", "photoURL", "role", "contributionScore", "badges", "createdAt"]
    },
    "CivicIssueReport": {
      "title": "CivicIssueReport",
      "description": "Community reported civic issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "address": { "type": "string" },
        "date": { "type": "string" },
        "createdAt": { "type": "string" },
        "reporterId": { "type": "string" },
        "reporterName": { "type": "string" },
        "reporterPhoto": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "assigned", "resolved", "rejected"] },
        "department": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "severity": { "type": "string" },
        "votesCount": { "type": "integer" },
        "upvotes": { "type": "integer" },
        "downvotes": { "type": "integer" },
        "verificationCount": { "type": "integer" },
        "rejectionsCount": { "type": "integer" },
        "verificationStatus": { "type": "string", "enum": ["unverified", "verified", "disputed"] },
        "timeline": { "type": "array" },
        "duplicatesMerged": { "type": "array" },
        "ward": { "type": "string" }
      },
      "required": [
        "description",
        "category",
        "latitude",
        "longitude",
        "address",
        "createdAt",
        "reporterId",
        "reporterName",
        "status",
        "department",
        "priority",
        "severity",
        "votesCount",
        "upvotes",
        "downvotes",
        "verificationCount",
        "rejectionsCount",
        "verificationStatus",
        "timeline",
        "duplicatesMerged",
        "ward"
      ]
    },
    "Comment": {
      "title": "Comment",
      "description": "Comment left on a reported civic issue",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reportId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["reportId", "userId", "userName", "content", "createdAt"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "User notification about updates on reported issues",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "title", "message", "read", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and scores"
    },
    "reports/{reportId}": {
      "schema": "CivicIssueReport",
      "description": "Civic issue reports"
    },
    "comments/{commentId}": {
      "schema": "Comment",
      "description": "User comments on civic issues"
    },
    "notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "Real-time user alerts and notifications"
    }
  }
}
